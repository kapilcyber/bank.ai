# TechBank.ai — reverse proxy for local dev (no :3005 in the browser URL)
# Placeholders __FRONTEND_UPSTREAM__ and __BACKEND_UPSTREAM__ are replaced at container start.
# Default: frontend Vite on host:3005, FastAPI on host:8000 (override via docker-compose env).

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    proxy_connect_timeout 60s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;

    upstream vite_main {
        server __FRONTEND_UPSTREAM__;
    }

    upstream vite_guest {
        server host.docker.internal:3008;
    }

    upstream vite_freelancer {
        server host.docker.internal:3006;
    }

    upstream vite_employee {
        server host.docker.internal:3007;
    }

    upstream api_dev {
        server __BACKEND_UPSTREAM__;
    }

    server {
        listen 80;
        # Accept any Host (LAN IP, localhost, etc.)
        server_name _;

        location = /guest {
            return 308 /guest/;
        }

        location = /freelancer {
            return 308 /freelancer/;
        }

        location = /employee {
            return 308 /employee/;
        }

        location = /techbank {
            return 308 /techbank/;
        }
        location ~ ^/admin(.*)$ {
            return 308 /techbank$1;
        }

        # Portals (npm run dev:portals:proxy on host)
        location /guest {
            proxy_pass http://vite_guest;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        location /freelancer {
            proxy_pass http://vite_freelancer;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        location /employee {
            proxy_pass http://vite_employee;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        # Main Vite dev server (SPA + HMR)
        location / {
            proxy_pass http://vite_main;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
        }

        # FastAPI (must match how app mounts routes — /api/ prefix)
        location /api/ {
            proxy_pass http://api_dev/api/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        location /docs {
            proxy_pass http://api_dev/docs;
            proxy_set_header Host $host;
        }

        location /openapi.json {
            proxy_pass http://api_dev/openapi.json;
            proxy_set_header Host $host;
        }

        location /uploads/ {
            proxy_pass http://api_dev/uploads/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }
}
