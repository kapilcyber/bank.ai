types {
    text/html                             html htm shtml;
    text/css                              css;
    text/xml                              xml;
    image/gif                             gif;
    image/jpeg                            jpeg jpg;
    image/png                             png;
    image/svg+xml                         svg svgz;
    image/x-icon                          ico;
    application/javascript                js;
    application/json                      json map;
    application/manifest+json             webmanifest;
    application/pdf                       pdf;
    application/wasm                      wasm;
    font/woff                             woff;
    font/woff2                            woff2;
    application/octet-stream              bin exe dll;
}
