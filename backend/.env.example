# MongoDB
MONGODB_URI=mongodb://localhost:27017/techbank
MONGODB_DB_NAME=techbank

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techbank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# Ollama
OLLAMA_BASE_URL=http://172.16.200.30:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_MAX_TOKENS=2000

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Server
PORT=8000
# HOST=0.0.0.0 for network access (other devices); HOST=127.0.0.1 for local-only
HOST=0.0.0.0
# CORS: use * to allow portals from any host (e.g. http://YOUR_IP:3005); or list origins comma-separated
# CORS_ORIGINS=*