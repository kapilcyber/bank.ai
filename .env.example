# Docker / TechBank.ai - Copy this file to .env and fill in values.
# Used by docker-compose and by backend/celery services.

# PostgreSQL (docker-compose overrides POSTGRES_HOST to service name)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=techbank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# Redis (required for Celery; use a strong password in production)
REDIS_PASSWORD=devredis

# Public URL of the app (for emails/links). Use https://yourdomain.com in production.
FRONTEND_BASE_URL=http://localhost

# JWT (change JWT_SECRET_KEY in production)
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Ollama (network-hosted model for AI features)
OLLAMA_BASE_URL=http://172.16.200.30:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_MAX_TOKENS=2000

# File upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# Server (backend)
PORT=8000
HOST=0.0.0.0
# CORS: * or comma-separated origins. In production, if API is exposed to other origins, set to specific allowed origins.
CORS_ORIGINS=*

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Microsoft Graph / Outlook
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=   <-- Must be the Secret VALUE from Azure (App registration → Certificates & secrets), NOT the Secret ID (GUID). Create a new secret if you don't have the value.
# MAILBOX_EMAIL=hr@techbank.ai

# --- Production ---
# Set strong POSTGRES_PASSWORD, JWT_SECRET_KEY, and REDIS_PASSWORD; never commit .env.
# Consider Docker secrets or a vault for real deployments.
# For HTTPS, place certs in nginx/ssl/ (cert.pem, key.pem) or use a reverse proxy in front.
