{
  "name": "techbank-ai-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:behind-proxy": "vite --mode behind-proxy",
    "dev:careers": "vite --config vite.config.careers.js --open /careers.html",
    "dev:guest": "vite --config vite.config.portal.js --mode portal-guest",
    "dev:freelancer": "vite --config vite.config.portal.js --mode portal-freelancer",
    "dev:employee": "vite --config vite.config.portal.js --mode portal-employee",
    "dev:guest:proxy": "vite --config vite.config.portal.js --mode portal-guest-proxy",
    "dev:freelancer:proxy": "vite --config vite.config.portal.js --mode portal-freelancer-proxy",
    "dev:employee:proxy": "vite --config vite.config.portal.js --mode portal-employee-proxy",
    "dev:portals": "concurrently -n guest,freelancer,employee -c cyan,magenta,green \"npm run dev:guest\" \"npm run dev:freelancer\" \"npm run dev:employee\"",
    "dev:portals:proxy": "concurrently -n guest,freelancer,employee -c cyan,magenta,green \"npm run dev:guest:proxy\" \"npm run dev:freelancer:proxy\" \"npm run dev:employee:proxy\"",
    "dev:guest:local": "vite --config vite.config.portal.js --mode portal-guest",
    "dev:freelancer:local": "vite --config vite.config.portal.js --mode portal-freelancer",
    "dev:employee:local": "vite --config vite.config.portal.js --mode portal-employee",
    "dev:portals:local": "concurrently -n guest,freelancer,employee -c cyan,magenta,green \"npm run dev:guest:local\" \"npm run dev:freelancer:local\" \"npm run dev:employee:local\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "apexcharts": "^5.3.6",
    "chart.js": "^4.5.1",
    "framer-motion": "^10.16.16",
    "jwt-decode": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "vite": "^5.0.8"
  }
}
